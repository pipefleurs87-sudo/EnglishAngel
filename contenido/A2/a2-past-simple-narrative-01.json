          [
            "Affirmative",
            "verb in past form (went, took, lost)",
            "Ben went to Cartagena"
          ],
          [
            "Negative",
            "did not (didn't) + base verb",
            "He didn't bring a map"
          ],
          [
            "Question",
            "Did + subject + base verb?",
            "Did Ben enjoy the trip?"
          ],
          [
            "Short answer",
            "Yes, he did. / No, he didn't.",
            "Did you go? Yes, I did."
          ],
          [
            "Story connectors",
            "first, then, because, so, luckily",
            "He lost his map, so he got lost"
          ]
        ]
      }
