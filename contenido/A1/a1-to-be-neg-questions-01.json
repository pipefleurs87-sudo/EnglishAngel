      "oracion": "Where is Sofía? Why are they late?"
    },
    {
      "id": "s8",
      "forma": "short_answer",
      "oracion": "Are you a student? Yes, I am."
    },
    {
      "id": "s9",
      "forma": "short_answer",
      "oracion": "Is Ben Colombian? No, he isn't."
    },
    {
      "id": "s10",
