  "fases": {
    "inicio": {
      "banner_diagnostico": {
        "opcion_a": "You are a teacher?",
        "opcion_b": "Are you a teacher?",
        "correcta": "b"
      },
      "definicion_pragmatica": "To ask a question with 'to be' we put the verb first (Are you...?), and to make it negative we add 'not' after the verb (She is not...).",
      "tabla": {
        "titulo": "Negative and contraction",
        "encabezados": [
          "Subject",
          "Negative",
          "Contraction"
        ],
        "filas": [
          [
            "I",
            "am not",
            "I'm not"
          ],
          [
            "He / She / It",
            "is not",
            "isn't"
          ],
          [
            "You / We / They",
            "are not",
            "aren't"
          ]
        ]
      },
      "vocab_warmup": false
    },
    "practica": {
      "ejercicios": [
        {
          "tipo": "multiple_choice",
          "pregunta": "___ you ready for the test?",
          "opciones": [
            "Is",
            "Are",
            "Am"
          ],
          "respuesta": "Are"
        },
        {
          "tipo": "multiple_choice",
          "pregunta": "Which question is correct?",
          "opciones": [
            "Ben is British?",
            "Is Ben British?",
            "British is Ben?"
          ],
          "respuesta": "Is Ben British?"
        },
        {
          "tipo": "true_false",
          "afirmacion": "To make a question with 'to be', we put the verb before the subject: 'Are you...?'.",
          "respuesta": "true"
        },
        {
          "tipo": "gap_fill",
          "texto": "___ Sofía from Bogotá? No, she is from Medellín.",
          "respuesta": "Is"
        },
        {
          "tipo": "gap_fill",
          "texto": "We ___ not at home right now.",
          "respuesta": "are"
        },
        {
          "tipo": "unscramble",
          "palabras": [
            "you",
            "Are",
            "tired",
            "?"
          ],
          "respuesta": "Are you tired?"
        },
        {
          "tipo": "correct_mistake",
          "texto_con_error": "She no is Japanese.",
          "respuesta": "She is not Japanese."
        },
        {
          "tipo": "transformation",
          "oracion_base": "Kenji is a student.",
          "instruccion": "Turn it into a question.",
          "respuesta": "Is Kenji a student?"
        },
        {
          "tipo": "transformation",
          "oracion_base": "They are ready.",
          "instruccion": "Make it negative (use 'not').",
          "respuesta": "They are not ready."
        },
        {
          "tipo": "short_answer_production",
          "pregunta": "Are you a teacher? (Answer: Yes, I am. / No, I'm not.)",
          "respuesta": "No, I'm not."
        }
      ]
    },
    "listening": {
      "guion": [
        "Kenji: Are you ready for the test, Ben?",
        "Ben: No, I'm not! I am very nervous.",
        "Kenji: Is it difficult?",
        "Ben: It is not easy. Are you nervous too?",
        "Kenji: No, I'm not. We are ready, don't worry."
      ],
      "gaps": [
        "ready",
        "nervous"
      ],
      "comprension": [
        {
          "pregunta": "Is Ben nervous?",
          "opciones": [
            "No, he is calm",
            "Yes, he is very nervous",
            "He is ready"
          ],
          "respuesta": "Yes, he is very nervous"
        },
        {
          "pregunta": "Is Kenji nervous?",
          "opciones": [
            "Yes, very",
            "No, he isn't",
            "A little"
          ],
          "respuesta": "No, he isn't"
        }
      ]
    },
    "reading": {
      "texto": "Ben is not Colombian; he is British. Today he is tired because he is not used to the heat. 'Are you okay, Ben?' asks Sofía. 'I am not sick,' he says, 'but I am very hot!' Sofía laughs. They are good friends, and they are happy in Medellín.",
      "preguntas": [
        {
          "afirmacion": "Ben is British.",
          "respuesta": "true"
        },
        {
          "afirmacion": "Ben is sick.",
          "respuesta": "false"
        },
        {
          "afirmacion": "Sofía and Ben are friends.",
          "respuesta": "true"
        }
      ]
    }
  }
