{
  "id": "a1-object-pronouns-01",
  "nivel": "A1",
  "arquetipo": "pronombres",
  "tema": "Object Pronouns (me, him, her, us, them)",
  "habilidades": [
    "grammar",
    "listening",
    "reading",
    "writing"
  ],
  "banco_oraciones": [
    {
      "id": "s1",
      "forma": "afirmativo",
      "oracion": "Sofía knows me, and I love her."
    },
    {
      "id": "s2",
      "forma": "afirmativo",
      "oracion": "They help us every day, so we thank them."
    },
    {
      "id": "s3",
      "forma": "negativo",
      "oracion": "Ben doesn't understand them very well."
    },
    {
      "id": "s4",
      "forma": "negativo",
      "oracion": "She doesn't call him on Sundays."
    },
    {
      "id": "s5",
      "forma": "interrogativo",
      "oracion": "Do you know her? Does he like us?"
    },
    {
      "id": "s6",
      "forma": "interrogativo",
      "oracion": "Why does Kenji always ask me questions?"
    },
    {
      "id": "s7",
      "forma": "short_answer",
      "oracion": "Do you know him? Yes, I do."
    },
    {
      "id": "s8",
      "forma": "short_answer",
      "oracion": "Does she call you? No, she doesn't."
    }
  ],
  "fases": {
    "inicio": {
      "banner_diagnostico": {
        "opcion_a": "I love she.",
        "opcion_b": "I love her.",
        "correcta": "b"
      },
      "definicion_pragmatica": "We use object pronouns (me, you, him, her, it, us, them) after the verb or a preposition — they receive the action.",
      "tabla": {
        "titulo": "Subject -> Object",
        "encabezados": [
          "Subject",
          "Object",
          "Example"
        ],
        "filas": [
          [
            "I",
            "me",
            "Sofía knows me"
          ],
          [
            "he",
            "him",
            "We know him"
          ],
          [
            "she",
            "her",
            "I love her"
          ],
          [
            "we",
            "us",
            "They help us"
          ],
          [
            "they",
            "them",
            "I call them"
          ]
        ]
      },
      "vocab_warmup": false
    },
    "practica": {
      "ejercicios": [
        {
          "tipo": "multiple_choice",
          "pregunta": "I see Ben. I see ___.",
          "opciones": [
            "he",
            "him",
            "his"
          ],
          "respuesta": "him"
        },
        {
          "tipo": "multiple_choice",
          "pregunta": "Sofía is nice. I like ___.",
          "opciones": [
            "she",
            "her",
            "hers"
          ],
          "respuesta": "her"
        },
        {
          "tipo": "true_false",
          "afirmacion": "Object pronouns (me, him, her...) come after the verb.",
          "respuesta": "true"
        },
        {
          "tipo": "gap_fill",
          "texto": "Please call ___ tonight. (to me)",
          "respuesta": "me"
        },
        {
          "tipo": "gap_fill",
          "texto": "We know Sofía and Ben. We know ___.",
          "respuesta": "them"
        },
        {
          "tipo": "correct_mistake",
          "texto_con_error": "I love she.",
          "respuesta": "I love her."
        },
        {
          "tipo": "transformation",
          "oracion_base": "I like Sofía.",
          "instruccion": "Replace 'Sofia' with an object pronoun.",
          "respuesta": "I like her."
        },
        {
          "tipo": "transformation",
          "oracion_base": "Sofía calls Ben.",
          "instruccion": "Replace 'Ben' with an object pronoun.",
          "respuesta": "Sofía calls him."
        },
        {
          "tipo": "short_answer_production",
          "pregunta": "Do you know me? (Answer: Yes, I do. / No, I don't.)",
          "respuesta": "Yes, I do."
        }
      ]
    },
    "listening": {
      "guion": [
        "Kenji: Sofía, do you know Ben's sister?",
        "Sofía: Yes, I know her. She is very nice.",
        "Kenji: Does she remember me?",
        "Sofía: Of course she remembers you! We all like you.",
        "Kenji: And Ben? Do you see him often?",
        "Sofía: Yes, I see him every week in class."
      ],
      "gaps": [
        "her",
        "you"
      ],
      "comprension": [
        {
          "pregunta": "Does Sofía know Ben's sister?",
          "opciones": [
            "Yes, she knows her",
            "No, she doesn't",
            "Only a little"
          ],
          "respuesta": "Yes, she knows her"
        },
        {
          "pregunta": "How often does Sofía see Ben?",
          "opciones": [
            "Never",
            "Every week",
            "Once a year"
          ],
          "respuesta": "Every week"
        }
      ]
    },
    "reading": {
      "texto": "Kenji is new, so he asks Sofía about everyone. 'Do you know that woman?' 'Yes, I know her.' 'And those men?' 'I know them too.' Kenji smiles. 'Everybody knows you, Sofía!' She laughs. 'Yes, and they like me because I help them. Friends help each other.'",
      "preguntas": [
        {
          "afirmacion": "Sofía knows the woman.",
          "respuesta": "true"
        },
        {
          "afirmacion": "Sofía doesn't know the men.",
          "respuesta": "false"
        },
        {
          "afirmacion": "People like Sofía because she helps them.",
          "respuesta": "true"
        }
      ]
    }
  }
}