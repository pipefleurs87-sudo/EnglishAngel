{
  "id": "a1-demonstratives-01",
  "nivel": "A1",
  "arquetipo": "determinantes",
  "tema": "This / That / These / Those",
  "habilidades": [
    "grammar",
    "reading",
    "writing"
  ],
  "banco_oraciones": [
    {
      "id": "s1",
      "forma": "afirmativo",
      "oracion": "This is my book, and these are my pens."
    },
    {
      "id": "s2",
      "forma": "afirmativo",
      "oracion": "That house is big, and those cars are fast."
    },
    {
      "id": "s3",
      "forma": "negativo",
      "oracion": "This is not my bag. These are not my keys."
    },
    {
      "id": "s4",
      "forma": "negativo",
      "oracion": "That isn't Sofía's house, and those aren't her shoes."
    },
    {
      "id": "s5",
      "forma": "interrogativo",
      "oracion": "Is this your pen? Are these your books?"
    },
    {
      "id": "s6",
      "forma": "interrogativo",
      "oracion": "Is that your car? Are those your friends?"
    },
    {
      "id": "s7",
      "forma": "short_answer",
      "oracion": "Is this your phone? Yes, it is."
    },
    {
      "id": "s8",
      "forma": "short_answer",
      "oracion": "Are those your keys? No, they aren't."
    }
  ],
  "fases": {
    "inicio": {
      "banner_diagnostico": {
        "opcion_a": "This shoes are nice.",
        "opcion_b": "These shoes are nice.",
        "correcta": "b"
      },
      "definicion_pragmatica": "We use this/these for what is near and that/those for what is far; this/that are singular and these/those are plural.",
      "tabla": {
        "titulo": "Near / Far · Singular / Plural",
        "encabezados": [
          "",
          "Cerca",
          "Lejos"
        ],
        "filas": [
          [
            "Singular",
            "this",
            "that"
          ],
          [
            "Plural",
            "these",
            "those"
          ]
        ]
      },
      "vocab_warmup": false
    },
    "practica": {
      "ejercicios": [
        {
          "tipo": "multiple_choice",
          "pregunta": "___ shoes here are new. (near, plural)",
          "opciones": [
            "This",
            "These",
            "That"
          ],
          "respuesta": "These"
        },
        {
          "tipo": "multiple_choice",
          "pregunta": "Look at ___ mountain over there. (far, singular)",
          "opciones": [
            "this",
            "these",
            "that"
          ],
          "respuesta": "that"
        },
        {
          "tipo": "true_false",
          "afirmacion": "'These' and 'those' are used with plural nouns.",
          "respuesta": "true"
        },
        {
          "tipo": "gap_fill",
          "texto": "___ apple in my hand is delicious. (near, singular)",
          "respuesta": "This"
        },
        {
          "tipo": "gap_fill",
          "texto": "___ birds in the sky are beautiful. (far, plural)",
          "respuesta": "Those"
        },
        {
          "tipo": "unscramble",
          "palabras": [
            "these",
            "Are",
            "shoes",
            "your",
            "?"
          ],
          "respuesta": "Are these your shoes?"
        },
        {
          "tipo": "correct_mistake",
          "texto_con_error": "Those car is expensive.",
          "respuesta": "That car is expensive."
        },
        {
          "tipo": "transformation",
          "oracion_base": "This book is interesting.",
          "instruccion": "Make it plural (this -> these).",
          "respuesta": "These books are interesting."
        },
        {
          "tipo": "transformation",
          "oracion_base": "This is my pen.",
          "instruccion": "Turn it into a question.",
          "respuesta": "Is this my pen?"
        },
        {
          "tipo": "short_answer_production",
          "pregunta": "Is this your phone? (Answer: Yes, it is. / No, it isn't.)",
          "respuesta": "Yes, it is."
        }
      ]
    },
    "reading": {
      "texto": "Sofía is at the market. 'This fruit here is fresh,' says the seller. 'These mangoes are sweet, but those papayas over there are not ready.' Sofía asks, 'Is that papaya ripe?' 'No, it isn't,' he says. 'But these mangoes are perfect.' Sofía smiles: 'Then I want this mango, please.'",
      "preguntas": [
        {
          "afirmacion": "The mangoes near the seller are sweet.",
          "respuesta": "true"
        },
        {
          "afirmacion": "The papaya is ripe.",
          "respuesta": "false"
        },
        {
          "afirmacion": "Sofía wants a mango.",
          "respuesta": "true"
        }
      ]
    }
  }
}