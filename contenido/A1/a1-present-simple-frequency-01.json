  "fases": {
    "inicio": {
      "banner_diagnostico": {
        "opcion_a": "Sofía wakes up always early.",
        "opcion_b": "Sofía always wakes up early.",
        "correcta": "b"
      },
      "definicion_pragmatica": "We use adverbs of frequency (always, usually, sometimes, never) to say how often we do something.",
      "tabla": {
        "titulo": "Where does the adverb go?",
        "encabezados": [
          "Structure",
          "Example"
        ],
        "filas": [
          [
            "Subject + adverb + verb",
            "She always works"
          ],
          [
            "Subject + 'to be' + adverb",
            "She is always ready"
          ]
        ]
      },
      "vocab_warmup": true
    },
    "practica": {
      "ejercicios": [
        {
          "tipo": "multiple_choice",
          "pregunta": "Which sentence is correct?",
          "opciones": [
            "She goes always to work.",
            "She always goes to work.",
            "She goes to work always."
          ],
          "respuesta": "She always goes to work."
        },
        {
          "tipo": "multiple_choice",
          "pregunta": "'always' is closest to ___% of the time.",
          "opciones": [
            "0%",
            "50%",
            "100%"
          ],
          "respuesta": "100%"
        },
        {
          "tipo": "true_false",
          "afirmacion": "Adverbs of frequency go BEFORE the main verb: 'I always study'.",
          "respuesta": "true"
        },
        {
          "tipo": "true_false",
          "afirmacion": "With 'to be', the adverb goes AFTER it: 'She is always ready'.",
          "respuesta": "true"
        },
        {
          "tipo": "gap_fill",
          "texto": "Sofía is organized, so she ___ (never) forgets a meeting.",
          "respuesta": "never"
        },
        {
          "tipo": "gap_fill",
          "texto": "Sofía goes to the gym twice ___ week.",
          "respuesta": "a"
        },
        {
          "tipo": "unscramble",
          "palabras": [
            "always",
            "Sofía",
            "up",
            "early",
            "wakes",
            "."
          ],
          "respuesta": "Sofía always wakes up early."
        },
        {
          "tipo": "correct_mistake",
          "texto_con_error": "I go never to bed late.",
          "respuesta": "I never go to bed late."
        },
        {
          "tipo": "correct_mistake",
          "texto_con_error": "She always is organized.",
          "respuesta": "She is always organized."
        },
        {
          "tipo": "transformation",
          "oracion_base": "Sofía cooks dinner.",
          "instruccion": "Add 'usually' in the correct place.",
          "respuesta": "Sofía usually cooks dinner."
        },
        {
          "tipo": "write_opposite",
          "oracion_base": "Ben is always on time.",
          "instruccion": "Change it using 'never'.",
          "respuesta": "Ben is never on time."
        },
        {
          "tipo": "short_answer_production",
          "pregunta": "How often do you exercise? (Answer with a frequency expression.)",
          "respuesta": "I exercise twice a week."
        }
      ]
    },
    "listening": {
      "guion": [
        "Kenji: Sofía, you are always so organized! What is your secret?",
        "Sofía: Well, I always wake up at six o'clock.",
        "Kenji: Every day?",
        "Sofía: Yes. I usually have breakfast, and I never skip it.",
        "Kenji: And exercise?",
        "Sofía: I go to the gym twice a week. But I never go to bed late."
      ],
      "gaps": [
        "always",
        "twice"
      ],
      "comprension": [
        {
          "pregunta": "How often does Sofía wake up at six?",
          "opciones": [
            "Once a week",
            "Every day",
            "Sometimes"
          ],
          "respuesta": "Every day"
        },
        {
          "pregunta": "How often does Sofía go to the gym?",
          "opciones": [
            "Every day",
            "Twice a week",
            "Never"
          ],
          "respuesta": "Twice a week"
        }
      ]
    },
    "reading": {
      "texto": "Sofía is always very organized. She always wakes up at six o'clock, and she usually has breakfast before work. She often works from home on Fridays. She goes to the gym twice a week, but she never watches TV during the week. On Sundays, she sometimes visits her Abuela Carmen. That is why she is never tired on Monday morning.",
      "preguntas": [
        {
          "afirmacion": "Sofía always wakes up at six o'clock.",
          "respuesta": "true"
        },
        {
          "afirmacion": "She watches TV every night during the week.",
          "respuesta": "false"
        },
        {
          "afirmacion": "Sofía sometimes visits her grandmother on Sundays.",
          "respuesta": "true"
        }
      ]
    }
  }
}