{
  "id": "a1-prepositions-time-01",
  "nivel": "A1",
  "arquetipo": "preposiciones",
  "tema": "Prepositions of Time (at, on, in)",
  "habilidades": [
    "grammar",
    "listening",
    "reading",
    "writing"
  ],
  "banco_oraciones": [
    {
      "id": "s1",
      "forma": "afirmativo",
      "oracion": "The class starts at eight o'clock on Monday."
    },
    {
      "id": "s2",
      "forma": "afirmativo",
      "oracion": "Sofía was born in July, in 1990."
    },
    {
      "id": "s3",
      "forma": "negativo",
      "oracion": "The shop is not open on Sundays."
    },
    {
      "id": "s4",
      "forma": "negativo",
      "oracion": "Ben doesn't work at night."
    },
    {
      "id": "s5",
      "forma": "interrogativo",
      "oracion": "What time does the class start? Is it on Monday?"
    },
    {
      "id": "s6",
      "forma": "interrogativo",
      "oracion": "When is your birthday? In December?"
    },
    {
      "id": "s7",
      "forma": "short_answer",
      "oracion": "Is the class at nine? Yes, it is."
    },
    {
      "id": "s8",
      "forma": "short_answer",
      "oracion": "Is the party on Friday? No, it isn't."
    }
  ],
  "fases": {
    "inicio": {
      "banner_diagnostico": {
        "opcion_a": "The class starts in eight o'clock.",
        "opcion_b": "The class starts at eight o'clock.",
        "correcta": "b"
      },
      "definicion_pragmatica": "We use 'at' for clock times, 'on' for days and dates, and 'in' for months, years and seasons.",
      "tabla": {
        "titulo": "at / on / in",
        "encabezados": [
          "Preposition",
          "Used for",
          "Example"
        ],
        "filas": [
          [
            "at",
            "clock times & night",
            "at 8, at night"
          ],
          [
            "on",
            "days & dates",
            "on Monday, on July 5th"
          ],
          [
            "in",
            "months, years, seasons",
            "in July, in 2026, in summer"
          ]
        ]
      },
      "vocab_warmup": false
    },
    "practica": {
      "ejercicios": [
        {
          "tipo": "multiple_choice",
          "pregunta": "The class starts ___ nine o'clock.",
          "opciones": [
            "at",
            "on",
            "in"
          ],
          "respuesta": "at"
        },
        {
          "tipo": "multiple_choice",
          "pregunta": "My birthday is ___ December.",
          "opciones": [
            "at",
            "on",
            "in"
          ],
          "respuesta": "in"
        },
        {
          "tipo": "true_false",
          "afirmacion": "We use 'on' for days of the week: 'on Monday'.",
          "respuesta": "true"
        },
        {
          "tipo": "gap_fill",
          "texto": "The party is ___ Friday. (day)",
          "respuesta": "on"
        },
        {
          "tipo": "gap_fill",
          "texto": "Sofía was born ___ 1990. (year)",
          "respuesta": "in"
        },
        {
          "tipo": "correct_mistake",
          "texto_con_error": "I wake up in six o'clock.",
          "respuesta": "I wake up at six o'clock."
        },
        {
          "tipo": "correct_mistake",
          "texto_con_error": "My birthday is on July.",
          "respuesta": "My birthday is in July."
        },
        {
          "tipo": "transformation",
          "oracion_base": "The class is at nine.",
          "instruccion": "Turn it into a question.",
          "respuesta": "Is the class at nine?"
        },
        {
          "tipo": "short_answer_production",
          "pregunta": "What time do you have English class? (Use 'at'.)",
          "respuesta": "At six o'clock."
        }
      ]
    },
    "listening": {
      "guion": [
        "Kenji: When is our English class, Ben?",
        "Ben: It's on Monday, at six o'clock.",
        "Kenji: And the exam?",
        "Ben: The exam is in December, I think.",
        "Kenji: Perfect. And your birthday?",
        "Ben: My birthday is on July 5th. Don't forget!"
      ],
      "gaps": [
        "Monday",
        "December"
      ],
      "comprension": [
        {
          "pregunta": "When is the English class?",
          "opciones": [
            "On Monday at six",
            "On Friday at eight",
            "In December"
          ],
          "respuesta": "On Monday at six"
        },
        {
          "pregunta": "When is Ben's birthday?",
          "opciones": [
            "In December",
            "On July 5th",
            "On Monday"
          ],
          "respuesta": "On July 5th"
        }
      ]
    },
    "reading": {
      "texto": "Sofía has a busy week. She has meetings on Monday and Wednesday, always at nine o'clock in the morning. In the evening, at about seven, she cooks dinner. Her English class is on Thursday. Her favourite time is the weekend: on Saturday she rests, and in the afternoon she visits Abuela Carmen. In summer, she takes a long holiday.",
      "preguntas": [
        {
          "afirmacion": "Sofía has meetings at nine o'clock.",
          "respuesta": "true"
        },
        {
          "afirmacion": "Her English class is on Sunday.",
          "respuesta": "false"
        },
        {
          "afirmacion": "She takes a holiday in summer.",
          "respuesta": "true"
        }
      ]
    }
  }
}