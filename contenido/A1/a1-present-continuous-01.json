  "fases": {
    "inicio": {
      "banner_diagnostico": {
        "opcion_a": "Right now, Sofía cooks dinner.",
        "opcion_b": "Right now, Sofía is cooking dinner.",
        "correcta": "b"
      },
      "definicion_pragmatica": "We use the present continuous (am/is/are + verb-ing) for actions happening now; the present simple for routines and things that are always true.",
      "tabla": {
        "titulo": "Present Simple (always) vs Present Continuous (now)",
        "encabezados": [
          "Present Simple — always",
          "Present Continuous — now"
        ],
        "filas": [
          [
            "What do you do?",
            "What are you doing now?"
          ],
          [
            "I work in a school.",
            "I am reading a book."
          ],
          [
            "What does your father do?",
            "What is your father doing now?"
          ],
          [
            "He is a doctor.",
            "He is cooking dinner."
          ]
        ]
      },
