    "listening": {
      "guion": [
        "Kenji: Ben, what do you do?",
        "Ben: I work in a bookshop.",
        "Kenji: And what are you doing now?",
        "Ben: Right now, I am drinking coffee and reading.",
        "Kenji: Sofía usually cooks on Sundays. What is she doing now?",
        "Ben: Ha! Right now she is dancing in the kitchen!"
      ],
      "gaps": [
        "work",
        "reading"
      ],
      "comprension": [
        {
          "pregunta": "What does Ben do (his job)?",
          "opciones": [
            "He cooks",
            "He works in a bookshop",
            "He dances"
          ],
          "respuesta": "He works in a bookshop"
        },
        {
          "pregunta": "What is Sofía doing now?",
          "opciones": [
            "Cooking",
            "Dancing",
            "Reading"
          ],
          "respuesta": "Dancing"
        }
      ]
    },
    "reading": {
      "texto": "There are two ways to talk about the present. Present simple is for your life in general: 'Sofía works in Medellín. Her father is a doctor.' Present continuous is for this exact moment: 'Right now, Sofía is drinking coffee, and her father is examining a patient.' See the difference? 'What do you do?' asks about your job. 'What are you doing?' asks about now. Two questions, two answers!",
      "preguntas": [
        {
          "afirmacion": "Present continuous is for this exact moment.",
          "respuesta": "true"
        },
        {
          "afirmacion": "'What do you do?' asks about right now.",
          "respuesta": "false"
        },
        {
          "afirmacion": "Present simple is for your life in general.",
          "respuesta": "true"
        }
      ]
    }
  }
