        {"tipo": "gap_fill", "texto": "My grandfather is ___ (viejo), and my baby sister is young.", "respuesta": "old"},
        {"tipo": "unscramble", "palabras": ["Sofía", "is", "a", "smart", "designer"], "respuesta": "Sofía is a smart designer"},
