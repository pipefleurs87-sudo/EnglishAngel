        {"tipo": "correct_mistake", "texto_con_error": "They are students talls.", "respuesta": "They are tall students."},
        {"tipo": "correct_mistake", "texto_con_error": "She has a car fast.", "respuesta": "She has a fast car."},
        {"tipo": "correct_mistake", "texto_con_error": "My friends are funnies.", "respuesta": "My friends are funny."},
        {"tipo": "transformation", "oracion_base": "Ben is a fast runner.", "instruccion": "Write the negative form.", "respuesta": "Ben isn't a fast runner."},
        {"tipo": "transformation", "oracion_base": "Kenji is a friendly person.", "instruccion": "Write the yes/no question.", "respuesta": "Is Kenji a friendly person?"},
        {"tipo": "transformation", "oracion_base": "Is she smart?", "instruccion": "Answer with a short answer (Yes).", "respuesta": "Yes, she is."},
        {"tipo": "write_opposite", "oracion_base": "The house is big.", "instruccion": "Write the opposite (use 'small').", "respuesta": "The house is small."},
        {"tipo": "write_opposite", "oracion_base": "They aren't tall.", "instruccion": "Write the affirmative form.", "respuesta": "They are tall."},
        {"tipo": "short_answer_production", "pregunta": "Are your friends funny? (short answer)", "respuesta": "Yes, they are."},
        {"tipo": "short_answer_production", "pregunta": "Is an ant big? (short answer, No)", "respuesta": "No, it isn't."}
      ]
