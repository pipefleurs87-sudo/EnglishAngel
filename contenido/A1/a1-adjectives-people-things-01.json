        {"tipo": "multiple_choice", "pregunta": "The opposite of 'big' is ___.", "opciones": ["strong", "short", "small"], "respuesta": "small"},
        {"tipo": "true_false", "afirmacion": "In English, adjectives go before the noun: 'a smart designer'.", "respuesta": "true"},
        {"tipo": "true_false", "afirmacion": "Adjectives take -s in plural: 'funnies friends'.", "respuesta": "false"},
        {"tipo": "gap_fill", "texto": "Abuela Carmen is old, but she is very ___ (fuerte).", "respuesta": "strong"},
