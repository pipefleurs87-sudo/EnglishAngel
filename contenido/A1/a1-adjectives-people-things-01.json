  "fases": {
    "inicio": {
      "interaccion": [
        "Kenji: Describe the team! Sofía is **a smart designer** and **a fast worker**.",
        "Sofía: Kenji is **a friendly student** with **big questions**.",
        "Ben: And I am **a funny photographer**! ...Why is everybody quiet?",
        "Abuela Carmen: You are **a good boy**, Ben. And I am **an old woman** with **strong opinions**."
      ],
      "banner_diagnostico": {
        "opcion_a": "They are students talls.",
        "opcion_b": "They are tall students.",
        "correcta": "b"
      },
      "definicion_pragmatica": "Adjectives describe people and things — in English they go BEFORE the noun and never take a plural: tall students, not 'students talls'.",
      "tabla": {
        "titulo": "Adjective rules",
        "encabezados": ["Rule", "Correct", "Wrong"],
        "filas": [
          ["Before the noun", "a beautiful city", "a city beautiful ✗"],
          ["No plural", "tall students", "talls students ✗"],
          ["After the verb 'to be'", "She is smart", "—"],
          ["Article + adjective + noun", "a funny photographer", "funny a photographer ✗"],
          ["Two adjectives", "a small old house", "—"]
        ]
      },
      "vocab_warmup": true
    },
    "practica": {
      "ejercicios": [
