            "behind the door"
          ]
        ]
      },
      "vocab_warmup": false
    },
    "practica": {
      "ejercicios": [
        {
          "tipo": "multiple_choice",
          "pregunta": "The book is ___ the table. (on)",
          "opciones": [
            "in",
            "on",
            "under"
          ],
          "respuesta": "on"
        },
        {
          "tipo": "multiple_choice",
          "pregunta": "The cat is ___ the chair. (under)",
          "opciones": [
            "on",
            "under",
            "next to"
          ],
          "respuesta": "under"
        },
        {
          "tipo": "true_false",
          "afirmacion": "'next to' means 'al lado de'.",
          "respuesta": "true"
        },
        {
          "tipo": "gap_fill",
          "texto": "The keys are ___ the bag. (inside)",
          "respuesta": "in"
        },
        {
          "tipo": "gap_fill",
          "texto": "Sofía sits ___ to Ben. (next to)",
          "respuesta": "next"
        },
        {
          "tipo": "correct_mistake",
          "texto_con_error": "The book is in the table.",
          "respuesta": "The book is on the table."
        },
        {
          "tipo": "unscramble",
          "palabras": [
            "is",
            "The",
            "under",
            "cat",
            "the",
            "bed",
            "."
          ],
          "respuesta": "The cat is under the bed."
        },
        {
          "tipo": "transformation",
          "oracion_base": "The pen is on the desk.",
          "instruccion": "Make it negative (use 'not').",
          "respuesta": "The pen is not on the desk."
        },
        {
          "tipo": "short_answer_production",
          "pregunta": "Where is your phone right now? (Use a preposition of place.)",
          "respuesta": "It is on the table."
        }
      ]
    },
    "listening": {
      "guion": [
        "Ben: Kenji, where are my keys? I can't find them!",
        "Kenji: Are they in your bag?",
        "Ben: No, they aren't in my bag.",
        "Kenji: Look under the books on the table.",
        "Ben: No... oh, wait! They are behind the laptop!",
        "Kenji: Next time, put them in your pocket!"
      ],
      "gaps": [
        "bag",
        "behind"
      ],
      "comprension": [
        {
          "pregunta": "Where are Ben's keys?",
          "opciones": [
            "In his bag",
            "Behind the laptop",
            "Under the chair"
          ],
          "respuesta": "Behind the laptop"
        },
        {
          "pregunta": "Where does Kenji say to put the keys next time?",
          "opciones": [
            "In his pocket",
            "On the table",
            "Under the books"
          ],
          "respuesta": "In his pocket"
        }
      ]
    },
    "reading": {
      "texto": "Ben's desk is a mess! His laptop is on the table, and his books are under the laptop. His phone is next to the coffee, and his keys are behind the computer. 'Where is my pen?' he asks. Sofía laughs and points. 'It's in your hand, Ben!' Poor Ben — he never finds anything.",
      "preguntas": [
        {
          "afirmacion": "Ben's laptop is on the table.",
          "respuesta": "true"
        },
        {
          "afirmacion": "Ben's keys are in his bag.",
          "respuesta": "false"
        },
        {
          "afirmacion": "Ben's pen is in his hand.",
          "respuesta": "true"
        }
      ]
    }
  }
