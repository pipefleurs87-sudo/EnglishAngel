{
  "id": "a1-present-simple-neg-questions-01",
  "nivel": "A1",
  "arquetipo": "tiempo_verbal",
  "tema": "Present Simple — Negatives & Questions",
  "habilidades": [
    "grammar",
    "listening",
    "reading",
    "writing"
  ],
  "banco_oraciones": [
    {
      "id": "s1",
      "forma": "afirmativo",
      "oracion": "Sofía works in Medellín and likes her job."
    },
    {
      "id": "s2",
      "forma": "afirmativo",
      "oracion": "Ben and Kenji study English every week."
    },
    {
      "id": "s3",
      "forma": "negativo",
      "oracion": "Sofía does not work on Sundays."
    },
    {
      "id": "s4",
      "forma": "negativo",
      "oracion": "I don't like coffee, and Ben doesn't drink tea."
    },
    {
      "id": "s5",
      "forma": "interrogativo",
      "oracion": "Do you like coffee? Does Sofía work in Medellín?"
    },
    {
      "id": "s6",
      "forma": "interrogativo",
      "oracion": "What do you do? Where does Kenji live?"
    },
    {
      "id": "s7",
      "forma": "short_answer",
      "oracion": "Do you speak English? Yes, I do."
    },
    {
      "id": "s8",
      "forma": "short_answer",
      "oracion": "Does Ben drink tea? No, he doesn't."
    }
  ],
  "fases": {
    "inicio": {
      "banner_diagnostico": {
        "opcion_a": "Does she works here?",
        "opcion_b": "Does she work here?",
        "correcta": "b"
      },
      "definicion_pragmatica": "To make negatives and questions in the present simple we use do/does + the base verb (no '-s'): the '-s' goes onto 'does'.",
      "tabla": {
        "titulo": "do / does in negatives and questions",
        "encabezados": [
          "Subject",
          "Negative",
          "Question"
        ],
        "filas": [
          [
            "I / You / We / They",
            "don't work",
            "Do you work?"
          ],
          [
            "He / She / It",
            "doesn't work",
            "Does she work?"
          ]
        ]
      },
      "vocab_warmup": false
    },
    "practica": {
      "ejercicios": [
        {
          "tipo": "multiple_choice",
          "pregunta": "___ Sofía work in Medellín?",
          "opciones": [
            "Do",
            "Does",
            "Is"
          ],
          "respuesta": "Does"
        },
        {
          "tipo": "multiple_choice",
          "pregunta": "Ben ___ like tea.",
          "opciones": [
            "don't",
            "doesn't",
            "isn't"
          ],
          "respuesta": "doesn't"
        },
        {
          "tipo": "true_false",
          "afirmacion": "After 'do' or 'does', the verb has no '-s': 'Does she work?', not 'Does she works?'.",
          "respuesta": "true"
        },
        {
          "tipo": "gap_fill",
          "texto": "___ you like coffee? No, I don't.",
          "respuesta": "Do"
        },
        {
          "tipo": "gap_fill",
          "texto": "Kenji ___ not speak Spanish very well.",
          "respuesta": "does"
        },
        {
          "tipo": "unscramble",
          "palabras": [
            "you",
            "Do",
            "English",
            "speak",
            "?"
          ],
          "respuesta": "Do you speak English?"
        },
        {
          "tipo": "correct_mistake",
          "texto_con_error": "He don't like coffee.",
          "respuesta": "He doesn't like coffee."
        },
        {
          "tipo": "transformation",
          "oracion_base": "Sofía likes her job.",
          "instruccion": "Make it negative (use 'does not').",
          "respuesta": "Sofía does not like her job."
        },
        {
          "tipo": "transformation",
          "oracion_base": "You speak English.",
          "instruccion": "Turn it into a question (use 'do').",
          "respuesta": "Do you speak English?"
        },
        {
          "tipo": "short_answer_production",
          "pregunta": "Do you speak English? (Answer: Yes, I do. / No, I don't.)",
          "respuesta": "Yes, I do."
        }
      ]
    },
    "listening": {
      "guion": [
        "Kenji: Do you like Colombian coffee, Ben?",
        "Ben: No, I don't! I prefer tea.",
        "Kenji: Really? Does Sofía drink coffee?",
        "Ben: Yes, she does. She drinks it every morning.",
        "Kenji: And you? Do you cook?",
        "Ben: No, I don't cook. I eat at restaurants!"
      ],
      "gaps": [
        "coffee",
        "tea"
      ],
      "comprension": [
        {
          "pregunta": "Does Ben like coffee?",
          "opciones": [
            "Yes, a lot",
            "No, he prefers tea",
            "Only in the morning"
          ],
          "respuesta": "No, he prefers tea"
        },
        {
          "pregunta": "Does Ben cook?",
          "opciones": [
            "Yes, every day",
            "No, he eats at restaurants",
            "Only on Sundays"
          ],
          "respuesta": "No, he eats at restaurants"
        }
      ]
    },
    "reading": {
      "texto": "Ben does not like coffee, but he loves tea. Every morning he asks Sofía, 'Do you want tea?' Sofía always says, 'No, thanks. I don't drink tea; I drink coffee.' They laugh. Kenji doesn't drink either — he prefers water. Do they agree on anything? Yes, they do: they all love arepas!",
      "preguntas": [
        {
          "afirmacion": "Ben loves tea.",
          "respuesta": "true"
        },
        {
          "afirmacion": "Sofía drinks tea every morning.",
          "respuesta": "false"
        },
        {
          "afirmacion": "They all love arepas.",
          "respuesta": "true"
        }
      ]
    }
  }
}