{
  "id": "a1-pronouns-possessives-01",
  "nivel": "A1",
  "arquetipo": "pronombres",
  "tema": "Subject Pronouns & Possessive Adjectives",
  "habilidades": [
    "grammar",
    "vocabulary",
    "reading",
    "writing"
  ],
  "vocabulario": [
    {
      "palabra": "I → my",
      "traduccion": "yo → mi"
    },
    {
      "palabra": "you → your",
      "traduccion": "tú → tu"
    },
    {
      "palabra": "he → his",
      "traduccion": "él → su (de él)"
    },
    {
      "palabra": "she → her",
      "traduccion": "ella → su (de ella)"
    },
    {
      "palabra": "it → its",
      "traduccion": "ello → su"
    },
    {
      "palabra": "we → our",
      "traduccion": "nosotros → nuestro"
    },
    {
      "palabra": "they → their",
      "traduccion": "ellos → su (de ellos)"
    }
  ],
  "banco_oraciones": [
    {
      "id": "s1",
      "forma": "afirmativo",
      "oracion": "She loves her job. He lost his hat."
    },
    {
      "id": "s2",
      "forma": "afirmativo",
      "oracion": "We like our teacher, and they enjoy their trip."
    },
    {
      "id": "s3",
      "forma": "negativo",
      "oracion": "This is not my book. That is not her bag."
    },
    {
      "id": "s4",
      "forma": "negativo",
      "oracion": "It isn't his pen, and they aren't our keys."
    },
    {
      "id": "s5",
      "forma": "interrogativo",
      "oracion": "Is this your pen? Is that his hat?"
    },
    {
      "id": "s6",
      "forma": "interrogativo",
      "oracion": "What is her name? Where are their friends?"
    },
    {
      "id": "s7",
      "forma": "short_answer",
      "oracion": "Is this your book? Yes, it is."
    },
    {
      "id": "s8",
      "forma": "short_answer",
      "oracion": "Is that her bag? No, it isn't."
    }
  ],
  "fases": {
    "inicio": {
      "banner_diagnostico": {
        "opcion_a": "She name is Sofía.",
        "opcion_b": "Her name is Sofía.",
        "correcta": "b"
      },
      "definicion_pragmatica": "Subject pronouns (I, you, he...) replace the name; possessive adjectives (my, your, his, her...) say who something belongs to.",
      "tabla": {
        "titulo": "Pronoun -> Possessive",
        "encabezados": [
          "Pronoun",
          "Possessive",
          "Example"
        ],
        "filas": [
          [
            "I",
            "my",
            "my book"
          ],
          [
            "you",
            "your",
            "your pen"
          ],
          [
            "he",
            "his",
            "his hat"
          ],
          [
            "she",
            "her",
            "her job"
          ],
          [
            "we",
            "our",
            "our teacher"
          ],
          [
            "they",
            "their",
            "their trip"
          ]
        ]
      },
      "vocab_warmup": true
    },
    "practica": {
      "ejercicios": [
        {
          "tipo": "multiple_choice",
          "pregunta": "Sofía loves ___ job.",
          "opciones": [
            "she",
            "her",
            "his"
          ],
          "respuesta": "her"
        },
        {
          "tipo": "multiple_choice",
          "pregunta": "Ben and I are friends. ___ are happy.",
          "opciones": [
            "We",
            "They",
            "Our"
          ],
          "respuesta": "We"
        },
        {
          "tipo": "true_false",
          "afirmacion": "'His' is the possessive for 'he', and 'her' is the possessive for 'she'.",
          "respuesta": "true"
        },
        {
          "tipo": "gap_fill",
          "texto": "Kenji is from Japan. ___ family lives in Tokyo.",
          "respuesta": "His"
        },
        {
          "tipo": "gap_fill",
          "texto": "We love ___ English teacher.",
          "respuesta": "our"
        },
        {
          "tipo": "unscramble",
          "palabras": [
            "is",
            "this",
            "Is",
            "your",
            "pen",
            "?"
          ],
          "respuesta": "Is this your pen?"
        },
        {
          "tipo": "correct_mistake",
          "texto_con_error": "They trip is next week.",
          "respuesta": "Their trip is next week."
        },
        {
          "tipo": "transformation",
          "oracion_base": "Sofía is a designer.",
          "instruccion": "Replace 'Sofia' with a subject pronoun.",
          "respuesta": "She is a designer."
        },
        {
          "tipo": "transformation",
          "oracion_base": "This is her bag.",
          "instruccion": "Turn it into a question.",
          "respuesta": "Is this her bag?"
        },
        {
          "tipo": "short_answer_production",
          "pregunta": "Is this your book? (Answer: Yes, it is. / No, it isn't.)",
          "respuesta": "Yes, it is."
        }
      ]
    },
    "reading": {
      "texto": "Sofía is a designer. She loves her job in Medellín. Her friend Ben is British; he lost his hat on his trip. Kenji is their other friend. He is from Japan, and his family lives in Tokyo. 'Is this your hat, Ben?' asks Sofía. 'No, it isn't,' he says. They laugh, because their English class is always fun.",
      "preguntas": [
        {
          "afirmacion": "Sofía loves her job.",
          "respuesta": "true"
        },
        {
          "afirmacion": "Ben found his hat.",
          "respuesta": "false"
        },
        {
          "afirmacion": "Kenji's family lives in Tokyo.",
          "respuesta": "true"
        }
      ]
    }
  }
