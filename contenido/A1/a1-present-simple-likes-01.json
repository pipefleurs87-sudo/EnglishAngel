  "fases": {
    "inicio": {
      "banner_diagnostico": {
        "opcion_a": "I like read books.",
        "opcion_b": "I like reading books.",
        "correcta": "b"
      },
      "definicion_pragmatica": "We use like/love/hate + a noun or a verb in '-ing' to talk about what we enjoy and our free time.",
      "tabla": {
        "titulo": "Preferences and structure",
        "encabezados": [
          "Preference",
          "Structure",
          "Example"
        ],
        "filas": [
          [
            "love ♥♥♥",
            "love + -ing",
            "I love dancing"
          ],
          [
            "like ♥♥",
            "like + -ing",
            "She likes reading"
          ],
          [
            "don't like ♥",
            "don't like + -ing",
            "I don't like cooking"
          ],
          [
            "hate ✗",
            "hate + -ing",
            "He hates swimming"
          ]
        ]
      },
      "vocab_warmup": true
    },
    "practica": {
      "ejercicios": [
        {
          "tipo": "multiple_choice",
          "pregunta": "Sofía loves ___.",
          "opciones": [
            "dance",
            "dancing",
            "to dancing"
          ],
          "respuesta": "dancing"
        },
        {
          "tipo": "multiple_choice",
          "pregunta": "___ Kenji like cooking?",
          "opciones": [
            "Do",
            "Does",
            "Is"
          ],
          "respuesta": "Does"
        },
        {
          "tipo": "true_false",
          "afirmacion": "After like/love/hate we often use the verb + '-ing': 'I like reading'.",
          "respuesta": "true"
        },
        {
          "tipo": "gap_fill",
          "texto": "Ben loves ___ to new countries. (travel)",
          "respuesta": "travelling"
        },
        {
          "tipo": "gap_fill",
          "texto": "___ you like listening to music? Yes, I do.",
          "respuesta": "Do"
        },
        {
          "tipo": "unscramble",
          "palabras": [
            "likes",
            "Sofía",
            "cooking",
            "."
          ],
          "respuesta": "Sofía likes cooking."
        },
        {
          "tipo": "correct_mistake",
          "texto_con_error": "Kenji like reading books.",
          "respuesta": "Kenji likes reading books."
        },
        {
          "tipo": "transformation",
          "oracion_base": "Sofía likes swimming.",
          "instruccion": "Make it negative (use 'does not').",
          "respuesta": "Sofía does not like swimming."
        },
        {
          "tipo": "transformation",
          "oracion_base": "You like dancing.",
          "instruccion": "Turn it into a question (use 'do').",
          "respuesta": "Do you like dancing?"
        },
        {
          "tipo": "short_answer_production",
          "pregunta": "Do you like cooking? (Answer: Yes, I do. / No, I don't.)",
          "respuesta": "Yes, I do."
        }
      ]
    },
    "listening": {
      "guion": [
        "Kenji: What do you like doing in your free time, Sofía?",
        "Sofía: I love dancing! And I like cooking on Sundays.",
        "Kenji: Do you like swimming?",
        "Sofía: No, I don't. I hate cold water!",
        "Kenji: And Ben?",
        "Sofía: Ben loves travelling. He never stays in one place."
      ],
      "gaps": [
        "dancing",
        "cooking"
      ],
      "comprension": [
        {
          "pregunta": "What does Sofía love doing?",
          "opciones": [
            "Swimming",
            "Dancing",
            "Watching TV"
          ],
          "respuesta": "Dancing"
        },
        {
          "pregunta": "Does Sofía like swimming?",
          "opciones": [
            "Yes, a lot",
            "No, she hates cold water",
            "Only in summer"
          ],
          "respuesta": "No, she hates cold water"
        }
      ]
    },
    "reading": {
      "texto": "Everyone in the group likes different things. Sofía loves dancing and enjoys cooking on Sundays, but she doesn't like swimming because she hates cold water. Ben loves travelling; he never stays in one place. Kenji likes reading and listening to music. 'Do you like the same things?' asks the teacher. 'No,' they laugh, 'but we all love learning English!'",
      "preguntas": [
        {
          "afirmacion": "Sofía loves dancing.",
          "respuesta": "true"
        },
        {
          "afirmacion": "Ben hates travelling.",
          "respuesta": "false"
        },
        {
          "afirmacion": "They all love learning English.",
          "respuesta": "true"
        }
      ]
    }
  }
