    "reading": {
      "texto": "Sofía is a designer in Medellín. Every day she wakes up at six o'clock. She has breakfast, and then she goes to work. She starts at eight and finishes at five. In the evening, she cooks dinner and goes to bed early. She does not work on Sundays; she rests and visits her family.",
      "preguntas": [
        {
          "afirmacion": "Sofía wakes up at six o'clock.",
          "respuesta": "true"
        },
        {
          "afirmacion": "She finishes work at eight.",
          "respuesta": "false"
        },
        {
          "afirmacion": "Sofía does not work on Sundays.",
          "respuesta": "true"
        }
      ]
