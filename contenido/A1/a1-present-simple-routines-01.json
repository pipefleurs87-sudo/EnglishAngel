    "practica": {
      "ejercicios": [
        {
          "tipo": "multiple_choice",
          "pregunta": "Sofía ___ up at six o'clock.",
          "opciones": [
            "wake",
            "wakes",
            "waking"
          ],
          "respuesta": "wakes"
        },
        {
          "tipo": "multiple_choice",
          "pregunta": "___ she work in Medellín?",
          "opciones": [
            "Do",
            "Does",
            "Is"
          ],
          "respuesta": "Does"
        },
        {
          "tipo": "true_false",
          "afirmacion": "With he/she/it, we add '-s' to the verb in the present simple.",
          "respuesta": "true"
        },
        {
          "tipo": "gap_fill",
          "texto": "She ___ breakfast before she goes to work. (have)",
          "respuesta": "has"
        },
        {
          "tipo": "gap_fill",
          "texto": "Sofía ___ not work on Sundays.",
          "respuesta": "does"
        },
        {
          "tipo": "unscramble",
          "palabras": [
            "work",
            "Sofía",
            "at",
            "starts",
            "eight",
            "."
          ],
          "respuesta": "Sofía starts work at eight."
        },
        {
          "tipo": "correct_mistake",
          "texto_con_error": "She go to work at seven.",
          "respuesta": "She goes to work at seven."
        },
        {
          "tipo": "transformation",
          "oracion_base": "Sofía cooks dinner every night.",
          "instruccion": "Make it negative (use 'does not').",
          "respuesta": "Sofía does not cook dinner every night."
        },
        {
          "tipo": "transformation",
          "oracion_base": "Sofía wakes up early.",
          "instruccion": "Turn it into a question (use 'does').",
          "respuesta": "Does Sofía wake up early?"
        },
        {
          "tipo": "short_answer_production",
          "pregunta": "What time do you wake up? (Answer with a full sentence.)",
          "respuesta": "I wake up at seven."
        }
      ]
    },
    "listening": {
